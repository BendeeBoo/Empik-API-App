# Ключ API Empik Marketplace (Панель продавца -> имя пользователя -> Klucz API -> Wygeneruj nowy klucz)
EMPIK_API_KEY=

# Базовый URL API. Боевой: https://marketplace.empik.com
# Тестовый (staging): https://stg1.marketplace.empik.com
EMPIK_BASE_URL=https://marketplace.empik.com

# Интервал проверки новых заказов в минутах (по умолчанию 60)
POLL_MINUTES=60

# Пароль для входа в веб-интерфейс (обязательно смените, интерфейс будет доступен из интернета!)
# Если пароль содержит символ #, возьмите его в кавычки: APP_PASSWORD="пароль#с#решётками"
APP_PASSWORD=change-me

# Порт локального сервера
PORT=3000
